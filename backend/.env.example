# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://foodwaste:foodwaste_secret@localhost:5432/foodwaste_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@foodwaste.app

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@foodwaste.app

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Claim Priority Windows (minutes)
CHARITY_WINDOW_MINUTES=120
TRUSTED_WINDOW_MINUTES=60
